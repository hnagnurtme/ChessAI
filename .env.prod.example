# Production Environment Variables
# Copy this file to .env.prod and update with your values

# Docker Hub credentials (for pushing images)
DOCKERHUB_USERNAME=your_dockerhub_username

# Docker image names (optional, defaults will be used if not set)
IMAGE_BACKEND=chess-bot-backend
IMAGE_FRONTEND=chess-bot-frontend

# Frontend API URL (used during Docker build)
# For production with nginx reverse proxy, use relative path
VITE_API_URL=/api

# Alternative: Full URL if not using reverse proxy
# VITE_API_URL=https://chess-ai.cloud.hnagnurtme.id.vn/api
